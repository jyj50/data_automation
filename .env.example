# ── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=changeme-insecure-key-please-change-in-production
DEBUG=true

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default for local dev). For production replace with:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./data/db.sqlite3

# ── Media ─────────────────────────────────────────────────────────────────────
MEDIA_ROOT=./media

# ── Document processing ────────────────────────────────────────────────────────
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=100

# ── Embedding ─────────────────────────────────────────────────────────────────
# none              → skip embedding (vector upsert will be no-op)
# sentence_transformer → use local BAAI/bge-m3 (requires torch)
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# ── Vector DB ─────────────────────────────────────────────────────────────────
VECTOR_DB_PROVIDER=chroma
# docker-compose local: use http://localhost:8001 from the host
# inside docker network: http://chroma:8000  (set via environment: in compose)
CHROMA_URL=http://localhost:8001
CHROMA_COLLECTION=documents

# ── LLM ───────────────────────────────────────────────────────────────────────
# openai_compat → call /v1/chat/completions on LLM_BASE_URL
# none           → disable LLM (fallback answers only)
LLM_PROVIDER=openai_compat
LLM_BASE_URL=http://localhost:11434
# EXAONE 3.5 7.8B 4-bit quantized — Ollama tag 확인: ollama list
LLM_MODEL=exaone3.5:7.8b-instruct-q4_K_M
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── CORS (comma-separated) ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
