# Python
__pycache__/
*.py[oc]
*.egg-info
build/
dist/
wheels/

# Environments / tooling
.venv
.pytest_cache
.ruff_cache

# Databases
db.sqlite3
*.sqlite3
data/

# Media / static artifacts
media/
